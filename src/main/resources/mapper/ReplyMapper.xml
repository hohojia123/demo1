<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.example.demo.mapper.ReplyMapper">

    <resultMap id="Reply" type="com.example.demo.model.pojo.Reply">
        <id property="id" column="reply_id"/>
        <result property="body" column="reply_body"/>
        <result property="time" column="reply_time"/>
        <association property="user" javaType="com.example.demo.model.pojo.User">
            <id property="id" column="user_id"/>
            <result property="name" column="user_name"/>
            <result property="avatar" column="user_avatar"/>
        </association>
        <association property="discuss" javaType="com.example.demo.model.pojo.Discuss">
            <id property="id" column="discuss_id"/>
            <association property="blog" javaType="com.example.demo.model.pojo.Blog">
                <id property="id" column="blog_id"/>
            </association>
        </association>
    </resultMap>

    <select id="findReplyByDiscussId" resultMap="Reply" parameterType="Integer">
        SELECT reply_id,reply_body,reply_time,u.user_id,u.user_name,u.user_avatar,r.discuss_id,r.reply_rootid
        FROM reply r LEFT JOIN user u on r.user_id = u.user_id LEFT JOIN discuss d on r.discuss_id = d.discuss_id
        WHERE r.discuss_id = #{value}
        ORDER BY r.reply_time
    </select>

    <select id="findReplyById" parameterType="Integer" resultMap="Reply">
        SELECT reply_id,reply_body,reply_time,u.user_id,u.user_name,u.user_avatar,r.discuss_id,r.reply_rootid,d.blog_id
        FROM reply r LEFT JOIN user u on r.user_id = u.user_id LEFT JOIN discuss d on r.discuss_id = d.discuss_id
        WHERE r.reply_id = #{value}
    </select>

    <insert id="saveReply" parameterType="com.example.demo.model.pojo.Reply">
        INSERT INTO reply
        VALUES (null,#{body},#{time},#{user.id},#{discuss.id},#{reply.id})
    </insert>



</mapper>